CREATE TABLE climbing_tiles_stats
(
  id                     INTEGER PRIMARY KEY AUTOINCREMENT,
  timestamp              TEXT,
  osm_data_timestamp     TEXT,
  build_log              TEXT,
  build_duration         INTEGER,
  max_size               INTEGER,
  max_size_zxy           TEXT,
  max_time               INTEGER,
  max_time_zxy           TEXT,
  groups_count           INTEGER,
  groups_with_name_count INTEGER,
  routes_count           INTEGER
);
